# ── Required ──────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here        # Get from: console.groq.com

# ── Document Settings ─────────────────────────────────────────
PDF_PATH=your_document.pdf                  # Path to your PDF file
PERSIST_DIRECTORY=./chroma_db              # Where ChromaDB will be stored
COLLECTION_NAME=my_collection              # ChromaDB collection name
DOCUMENT_DESCRIPTION=the uploaded PDF document  # Used in prompts

# ── Model Settings (optional — defaults provided) ─────────────
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5     # Runs locally, no API key needed

# ── Chunking Settings (optional) ──────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=5
